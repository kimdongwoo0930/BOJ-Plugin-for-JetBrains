<idea-plugin>
    <id>com.github.kimdongwoo0930.bojpluginforjetbrains</id>
    <name>BOJ Assistant</name>
    <vendor url="https://github.com/kimdongwoo0930">kimdongwoo0930</vendor>
    <description>백준 온라인 저지(BOJ)를 JetBrains IDE에서 사용할 수 있는 플러그인</description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow factoryClass="com.github.kimdongwoo0930.bojpluginforjetbrains.toolWindow.MyToolWindowFactory"
                    id="BOJ"
                    anchor="left"/>
        <fileEditorProvider implementation="com.github.kimdongwoo0930.bojpluginforjetbrains.toolWindow.ProblemViewerProvider"/>
        <postStartupActivity implementation="com.github.kimdongwoo0930.bojpluginforjetbrains.startup.MyProjectActivity" />
    </extensions>
    <incompatible-with>com.intellij.modules.rider</incompatible-with>
    <incompatible-with>com.intellij.modules.clion</incompatible-with>
    <incompatible-with>com.intellij.modules.webstorm</incompatible-with>
    <incompatible-with>com.intellij.modules.goland</incompatible-with>
    <incompatible-with>com.intellij.modules.dataspell</incompatible-with>
    <incompatible-with>com.intellij.modules.rubymine</incompatible-with>
    <incompatible-with>com.intellij.modules.appcode</incompatible-with>
</idea-plugin>